{
  "info": {
    "name": "Food Order API",
    "description": "Complete API collection for the Food Ordering Management System with CI/CD Pipeline. This collection covers all CRUD operations for menu items and orders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "k8sUrl",
      "value": "http://food-order.local",
      "type": "string",
      "description": "Kubernetes ingress URL"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Health check endpoints for monitoring and CI/CD pipeline verification",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Check if the API is healthy and running. Returns status and timestamp."
          },
          "response": [
            {
              "name": "Healthy Response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"healthy\",\n  \"timestamp\": \"2024-01-15T10:30:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Stats",
      "description": "Dashboard statistics endpoints",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats"]
            },
            "description": "Get dashboard statistics including total items, orders, revenue, and order counts by status"
          },
          "response": [
            {
              "name": "Stats Response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"totalItems\": 8,\n  \"totalOrders\": 15,\n  \"totalRevenue\": 342.50,\n  \"pendingOrders\": 3,\n  \"completedOrders\": 10\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Menu",
      "description": "CRUD operations for menu items (food items)",
      "item": [
        {
          "name": "Get All Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menu",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu"]
            },
            "description": "Retrieve all food items from the menu with all details including images, ratings, prep time, and dietary info"
          },
          "response": []
        },
        {
          "name": "Get Menu Item by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menu/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu", "1"]
            },
            "description": "Retrieve a specific food item by its ID"
          },
          "response": []
        },
        {
          "name": "Add New Menu Item (Full)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grilled Salmon\",\n  \"description\": \"Fresh Atlantic salmon with lemon herb butter, served with seasonal vegetables and rice pilaf\",\n  \"price\": 24.99,\n  \"category\": \"main\",\n  \"available\": true,\n  \"image\": \"/images/steak.jpg\",\n  \"rating\": 4.7,\n  \"prepTime\": 20,\n  \"calories\": 450,\n  \"spicyLevel\": 0,\n  \"isVegetarian\": false,\n  \"isVegan\": false,\n  \"allergens\": [\"fish\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu"]
            },
            "description": "Add a new food item to the menu with all optional fields"
          },
          "response": []
        },
        {
          "name": "Add New Menu Item (Basic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Garden Salad\",\n  \"description\": \"Fresh mixed greens with cherry tomatoes, cucumber, and house dressing\",\n  \"price\": 8.99,\n  \"category\": \"appetizer\",\n  \"available\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu"]
            },
            "description": "Add a new food item with only required fields"
          },
          "response": []
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Premium Cheeseburger\",\n  \"price\": 16.99,\n  \"available\": true,\n  \"rating\": 4.9,\n  \"prepTime\": 12\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu", "1"]
            },
            "description": "Update an existing food item (partial update supported)"
          },
          "response": []
        },
        {
          "name": "Toggle Availability",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu", "1"]
            },
            "description": "Toggle the availability of a menu item"
          },
          "response": []
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menu/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu", "1"]
            },
            "description": "Delete a food item from the menu"
          },
          "response": []
        }
      ]
    },
    {
