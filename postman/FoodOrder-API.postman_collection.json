              "raw": "{\n  \"customerName\": \"John Doe\",\n  \"customerPhone\": \"(555) 123-4567\",\n  \"customerAddress\": \"123 Main St, Apt 4B, New York, NY 10001\",\n  \"notes\": \"Please ring the doorbell. Extra napkins please.\",\n  \"items\": [\n    {\n      \"foodItemId\": \"1\",\n      \"foodItemName\": \"Classic Cheeseburger\",\n      \"quantity\": 2,\n      \"price\": 14.99\n    },\n    {\n      \"foodItemId\": \"2\",\n      \"foodItemName\": \"Margherita Pizza\",\n      \"quantity\": 1,\n      \"price\": 18.99\n    },\n    {\n      \"foodItemId\": \"8\",\n      \"foodItemName\": \"Chocolate Lava Cake\",\n      \"quantity\": 2,\n      \"price\": 9.99\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            },
            "description": "Create a new order with full customer details and notes"
          },
          "response": []
