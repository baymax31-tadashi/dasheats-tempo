              "raw": "{\n  \"customerName\": \"Jane Smith\",\n  \"items\": [\n    {\n      \"foodItemId\": \"4\",\n      \"foodItemName\": \"Caesar Salad\",\n      \"quantity\": 1,\n      \"price\": 12.99\n    }\n  ]\n}"
